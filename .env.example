# ============================================================
# Daily Secretary - Environment variables
# Copy this file to ".env" for local testing.
# In production (GitHub Actions), set these as repository SECRETS.
# ============================================================

# --- Email (Gmail SMTP) ---
# Use a Gmail "App Password" (NOT your normal password):
# https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=leoshancx@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
RECIPIENT_EMAIL=leoshancx@gmail.com

# --- NewsAPI (https://newsapi.org/register) ---
# Free tier: 100 requests/day
NEWSAPI_KEY=your_newsapi_key_here

# --- Google Calendar OAuth ---
# Generated by running `python setup_google_auth.py` locally once.
# Paste the resulting token.json contents as a single line here.
GOOGLE_TOKEN_JSON={"token": "...", "refresh_token": "...", "token_uri": "https://oauth2.googleapis.com/token", "client_id": "...", "client_secret": "...", "scopes": ["https://www.googleapis.com/auth/calendar.readonly"]}

# --- User context ---
USER_NAME=Leo
USER_CITY=Paris
USER_LATITUDE=48.8566
USER_LONGITUDE=2.3522
USER_TIMEZONE=Europe/Paris
USER_GRADE=Grade 12 (Terminale)
USER_COUNTRY=France
